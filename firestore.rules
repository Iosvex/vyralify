rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function isAdmin() { return signedIn() && (request.auth.token.email == 'support@vyralify.in' || request.auth.token.email == 'vyralify.io@gmail.com' || (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')); }
    function validInitialProfile() { return request.resource.data.role == 'member' && request.resource.data.tier == 'free' && request.resource.data.keys().hasOnly(['email','displayName','role','tier','country','currency','billingProvider','onboardingTrack','createdAt','updatedAt']) && request.resource.data.currency in ['INR','USD'] && request.resource.data.billingProvider in ['razorpay','stripe']; }
    match /users/{uid} { allow get: if signedIn() && (request.auth.uid == uid || isAdmin()); allow list: if isAdmin(); allow create: if signedIn() && request.auth.uid == uid && validInitialProfile(); allow update: if isAdmin() || (signedIn() && request.auth.uid == uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName','country','currency','billingProvider','onboardingTrack','updatedAt']) && request.resource.data.role == resource.data.role && request.resource.data.tier == resource.data.tier && request.resource.data.subscriptionId == resource.data.subscriptionId && request.resource.data.subscriptionStatus == resource.data.subscriptionStatus); allow delete: if isAdmin(); }
    match /contentAssets/{document} { allow read: if true; allow write: if isAdmin(); }
    match /orders/{id} { allow get: if signedIn() && (resource.data.uid == request.auth.uid || isAdmin()); allow list: if isAdmin(); allow write: if false; }
    match /paidEmails/{key} { allow read: if isAdmin(); allow write: if false; }
    match /aiGenerations/{id} { allow read, write: if isAdmin(); }
    match /affiliates/{id} { allow get: if signedIn() && (resource.data.ownerUid == request.auth.uid || isAdmin()); allow list, write: if isAdmin(); }
    function validPost() { return request.resource.data.uid == request.auth.uid && request.resource.data.keys().hasOnly(['uid','displayName','channel','body','createdAt']) && request.resource.data.channel in ['introductions','general','networking','wins','reviews'] && request.resource.data.body is string && request.resource.data.body.size() > 0 && request.resource.data.body.size() <= 1000 && request.resource.data.displayName is string && request.resource.data.displayName.size() <= 80; }
    match /communityPosts/{id} { allow read: if signedIn(); allow create: if signedIn() && validPost(); allow update, delete: if signedIn() && resource.data.uid == request.auth.uid; }
  }
}
