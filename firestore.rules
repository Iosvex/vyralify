rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper to determine if user is an administrator
    function isAdmin() {
      return request.auth != null && (
        // Database role verification
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        // Hardcoded admin email backups
        request.auth.token.email == 'support@vyralify.in' ||
        request.auth.token.email == 'vyralify.io@gmail.com'
      );
    }

    // Anyone can read content assets (we handle tier filtering on frontend)
    match /contentAssets/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Users can read/write their own profiles
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null && request.auth.uid == uid;
    }
    
    // Administrators can read/write everything in the database
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
